# Context Engine — Environment Variables Template
# Skopíruj tento súbor ako .env a vyplň hodnoty.
# NIKDY necommituj .env do gitu (.gitignore to už blokuje).

# === Lokálna inštalácia ===

# Cesta k SQLite databáze (default: ~/.context-engine/context-engine.db)
CTX_DB=/Users/your_name/.context-engine/context-engine.db

# === Railway / produkčný deployment ===

# Cesta k DB na Railway volume (volume musí byť mountnutý na /data)
# CTX_DB=/data/context-engine.db

# Host & port (default: 0.0.0.0:8000)
CTX_HOST=0.0.0.0
CTX_PORT=8000

# === OAuth / Auth (pre Railway s OAuth) ===

# Basic auth pre OAuth server
CTX_OAUTH_USER=your_username
CTX_OAUTH_PASS=generate_a_strong_random_password_here

# API key pre Bearer token auth (alternatíva k OAuth pre agentov)
# Default = CTX_OAUTH_PASS, ale môžeš nastaviť samostatný
# CTX_API_KEY=separate_api_key_for_agents

# Verejná URL servera (potrebné pre OAuth callback)
CTX_SERVER_URL=https://your-instance.up.railway.app
